{
  "name": "pokemon-battle",
  "version": "1.0.0",
  "description": "A Pokemon battle game with TUI interface",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pokemon-battle": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npx ts-node src/index.ts",
    "start:server": "node dist/src/game/server/server.js",
    "dev:server": "npx ts-node src/game/server/server.ts"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "inquirer": "^8.2.7",
    "keypress": "^0.2.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
